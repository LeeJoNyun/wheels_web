# wheels_api (Express) — OAuth 후 프로필 동기화 POST /auth/sync-profile
# 로컬: http://localhost:4000
NEXT_PUBLIC_WHEELS_API_URL=http://localhost:4000
# 서버 전용(선택). SSR Route Handler에서 다른 호스트를 쓸 때
# WHEELS_API_URL=http://wheels_api:4000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key

# 구 anon JWT 키만 있을 때 (선택)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt

# 카카오 REST API 키. Supabase Kakao 프로바이더 Client ID 와 동일.
NEXT_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key

# 카카오 로그인 Client Secret (서버 전용). 플랫폼 키 → REST API 키 편집에서 확인. /auth/kakao 콜백에서 토큰 교환에 사용.
# Kakao Redirect URI에 {접속 호스트}/auth/kakao/callback 등록 (터미널 포트와 동일, 예: http://localhost:3001/auth/kakao/callback)
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# KOE205 시: 카카오 콘솔에서「OpenID Connect 사용」ON 필수. 고급: scope 덮어쓰기 (기본: openid profile_nickname profile_image)
# KAKAO_LOGIN_SCOPES=openid profile_nickname profile_image

# 네이버 로그인 (Supabase 기본 미지원 → /auth/naver 수동 OAuth)
# 네이버 개발자센터 Application의 Client ID / Client Secret. Callback: {호스트}/auth/naver/callback
NEXT_PUBLIC_NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 네이버 콜백에서 Supabase 사용자 생성·세션용. 절대 클라이언트/깃에 노출 금지.
# Supabase → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt

# --- Google 로그인 (선택) ---
# Next 앱에는 별도 키 불필요. Supabase Dashboard → Authentication → Providers → Google 에 Client ID/Secret 입력.
# Google Cloud Console → OAuth 2.0 클라이언트 → 승인된 리디렉션 URI:
#   https://<project-ref>.supabase.co/auth/v1/callback
# Supabase → Authentication → URL Configuration → Redirect URLs 에 http://localhost:3000/auth/callback 등 추가.
